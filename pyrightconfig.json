{


let mapleader = " "

"
" =========================
 
" =========================
" TEMAS DISPONIBLES
" =========================
let g:themes = ['gruvbox', 'tokyonight', 'catppuccin', 'kanagawa']
let g:theme_index = 0

" =========================
" FUNCIÓN PARA CAMBIAR TEMA
" =========================
function! CycleThemes()
  let g:theme_index = (g:theme_index + 1) % len(g:themes)
  execute 'colorscheme' g:themes[g:theme_index]
  echo "Theme: " . g:themes[g:theme_index]
endfunction

" =========================
" ATAJO LEADER + m
" =========================
nnoremap <leader>m :call CycleThemes()<CR>

" =========================
" TEMA INICIAL
" =========================
colorscheme gruvbox

  "typeCheckingMode": "off"
}
